(defwidget left []
	(box
		:space-evenly false
		:halign "start"
		(workspaces)
	)
)

(defwidget center []
	(box
		:space-evenly false
		:halign "center"
	)
)

(defwidget right []
	(box
		:space-evenly false
		:halign "end"
	)
)

(defwidget bar-box []
	(centerbox
		(left)
		(center)
		(right)
	)
)


(defwindow bar
	:monitor 0
	:geometry (geometry
		:x "0%"
		:y "0%"
		:width "100%"
		:height "32px"
		:anchor "top center"
	)
	:stacking "fg"
	:exclusive true
	:namespace "bar"
	(bar-box)
)
